<Project Sdk="Microsoft.NET.Sdk.Razor">

    <PropertyGroup>
        <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
        <NoWarn>$(NoWarn);1591</NoWarn>
        <Description>Manager panel for Aero CMS for AspNetCore</Description>
    </PropertyGroup>

    <PropertyGroup Condition="'$(GITHUB_ACTIONS)' == 'true'">
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Aero.Cms\Aero.Cms.csproj" />
        <ProjectReference Include="..\Aero.Cms.AspNetCore.Hosting\Aero.Cms.AspNetCore.Hosting.csproj" />
        <ProjectReference Include="..\Aero.Cms.Manager.Localization\Aero.Cms.Manager.Localization.csproj" />
    </ItemGroup>


    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" Version="10.0.4" />
        <PackageReference Update="Microsoft.SourceLink.GitHub" Version="10.0.200" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Include="assets\dist\**\*"/>
    </ItemGroup>

    <ItemGroup>
        <Compile Remove="node_modules\**"/>
        <Content Remove="package.json"/>
        <Content Remove="package-lock.json"/>
    </ItemGroup>

</Project>
