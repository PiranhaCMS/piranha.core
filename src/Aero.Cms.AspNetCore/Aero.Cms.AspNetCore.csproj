  <ItemGroup>
    <ProjectReference Include="..\Aero.Cms\Aero.Cms.csproj" />
    <ProjectReference Include="..\Aero.Cms.AspNetCore.Hosting\Aero.Cms.AspNetCore.Hosting.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="X.Web.Sitemap" Version="2.10.1" />
